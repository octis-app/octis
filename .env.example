# Octis — environment variables
# Copy this file to .env (or use as an EnvironmentFile in systemd)

# ── Required ──────────────────────────────────────────────────────────────────
GATEWAY_URL=wss://your-openclaw-host/gateway
GATEWAY_TOKEN=your-gateway-token-here

# ── Auth (optional) ───────────────────────────────────────────────────────────
# If ADMIN_PASSWORD is not set, Octis runs in auto-auth mode (no login screen).
# Fine for local/VPN use. Set both for multi-user or internet-exposed installs.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=changeme

# ── Server (optional) ─────────────────────────────────────────────────────────
OCTIS_API_PORT=3747
OCTIS_WORKSPACE=/path/to/.openclaw/workspace   # default: ~/.openclaw/workspace

# ── Costs panel (optional) ────────────────────────────────────────────────────
# Requires OpenClaw Postgres with raw_nexus.claw_session_costs table
# COSTS_DB_URL=postgresql://user:pass@host:5432/dbname

# ── Push notifications (optional) ────────────────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT=mailto:you@example.com
