app.post('/api/session-projects', requireAuth, async (req, res) => {
  const { sessionKey, projectTag, skipInject } = req.body;
  if (!sessionKey) return res.status(400).json({ error: 'sessionKey required' });
  
  // Get current project to detect if this is a change
  db.get('SELECT project FROM octis_session_projects WHERE session_key = ?', [sessionKey], async (err, current) => {
    if (err) {
      console.error('[server] Getting session-project error:', err.message);
      return res.status(500).json({ error: 'Database error retrieving current project' });
    }
    
    const oldProject = current?.project || null;
    
    if (!projectTag) {
      // Removing from project
      db.run('DELETE FROM octis_session_projects WHERE session_key = ?', [sessionKey], async (err) => {
        if (err) {
          console.error('[server] Removing session-project error:', err.message);
          return res.status(500).json({ error: 'Database error removing from project' });
        }
        
        // Inject removal notification only if there WAS a project before
        if (oldProject && !skipInject) {
          try {
            const msg = `This session has been **removed from its project**. It is now unassigned.`;
            await adminGwCall([`chat.inject session:${sessionKey} --message "${msg}"`]);
          } catch (injectErr) {
            console.error('[server] project-remove inject error:', injectErr.message);
          }
        }
        res.json({ ok: true });
      });
    } else {
      // Setting/changing project
      const stmt = `INSERT INTO octis_session_projects (session_key, project) VALUES (?, ?)
                      ON CONFLICT(session_key) DO UPDATE SET project = excluded.project, updated_at=CURRENT_TIMESTAMP`;
      
      db.run(stmt, [sessionKey, projectTag], async (err) => {
        if (err) {
          console.error('[server] Setting session-project error:', err.message);
          return res.status(500).json({ error: 'Database error setting project' });
        }
        
        // Only inject if this is a CHANGE (not initial set) and skipInject flag is not set
        // Initial assignment is handled by session-init endpoint (could be called on first message via pendingProjectInit)
        if (oldProject && oldProject !== projectTag && !skipInject) {
          try {
            // Retrieve the project details to include in the message
            db.get('SELECT * FROM octis_projects WHERE slug = ?', [projectTag], async (projErr, project) => {
              if (projErr || !project) {
                console.error('[server] Retrieving project for message inject error:', projErr?.message);
              } else {
                const { name, emoji, description, memory_file } = project;
                const descLine = description ? `\n${description}` : '';
                const memLine = memory_file ? `\nContext file: memory/${memory_file}` : '';
                const msg = `This session has been **moved to the ${emoji} ${name} project**.${descLine}${memLine}\n\nWhen the user asks which project this session is under, answer: **${name}**.`;

                try {
                  await adminGwCall([`chat.inject --session --message "${msg}" --label '📁 Project'`]);
                } catch (injectErr) {
                  console.error('[server] project-set inject error:', injectErr.message);
                }
              }
            });
          } catch (err) {
            console.error('[server] project-set error:', err.message);
          }
        }
        
        res.json({ ok: true });
      });
    }
  });
});

