      recentLogs = dateFiles.map(f => ({
        date: f.replace('.md', ''),
        content: fs.readFileSync(path.join(MEMORY_DIR, f), 'utf8')
      }));
    }
    
    let projects = [];
    if (fs.existsSync(MEMORY_DIR)) {
      const files = fs.readdirSync(MEMORY_DIR);
      const projectFiles = files.filter(f => f.endsWith('.md') && !/^\d{4}-\d{2}-\d{2}/.test(f));
      projects = projectFiles.map(f => ({
        name: f.replace('.md', ''),
        preview: fs.readFileSync(path.join(MEMORY_DIR, f), 'utf8').substring(0, 500),
      }));
    }
    
    res.json({ memory, todos, recentLogs, projects });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

