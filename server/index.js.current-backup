        input_tokens: parseInt(r.input_tokens || 0),
        output_tokens: parseInt(r.output_tokens || 0),
        cache_write_tokens: parseInt(r.cache_write_tokens || 0),
        cache_read_tokens: parseInt(r.cache_read_tokens || 0),
