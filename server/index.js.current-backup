app.get('/api/project-memory/:slug', (req, res) => {
  try {
    db.get('SELECT memory_file, description FROM octis_projects WHERE slug = ?', [req.params.slug], (err, project) => {
      if (err) {
        console.error('[server] Project memory get error:', err.message);
        return res.status(500).json({ error: 'Database error' });
      }
      
      // Look for the project memory file in the usual places
      let content = '';
      if (project?.memory_file) {
        const projectMemoryFile = path.join(WORKSPACE, project.memory_file);
        if (fs.existsSync(projectMemoryFile)) {
          try { content = fs.readFileSync(projectMemoryFile, 'utf8'); } catch {}
        }
      }
      
      // Fallback to memory files folder in the workspace
      if (!content) {
        const legacyPath = path.join(MEMORY_DIR, `${req.params.slug}.md`);
        if (fs.existsSync(legacyPath)) {
          try { content = fs.readFileSync(legacyPath, 'utf8'); } catch {}
        }
      }
      
      res.json({ content: content.substring(0, 800), description: project?.description || '' });
    });
  } catch (err) {
    res.json({ content: '' });
  }
});

