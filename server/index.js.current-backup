  const { id } = req.params;
  const { name, emoji, color, description, memory_file, position, hide_from_sessions } = req.body;
  const sets = [];
  const vals = [];
  if (name !== undefined)               { sets.push('name=?');                vals.push(name); }
  if (emoji !== undefined)              { sets.push('emoji=?');               vals.push(emoji); }
  if (color !== undefined)              { sets.push('color=?');               vals.push(color); }
  if (description !== undefined)        { sets.push('description=?');         vals.push(description); }
  if (memory_file !== undefined)        { sets.push('memory_file=?');         vals.push(memory_file); }
  if (position !== undefined)           { sets.push('position=?');            vals.push(position); }
  if (hide_from_sessions !== undefined) { sets.push('hide_from_sessions=?');  vals.push(hide_from_sessions ? 1 : 0); }
  if (sets.length === 0) {
    return res.status(400).json({ error: 'nothing to update' });
  }
  sets.push('updated_at=CURRENT_TIMESTAMP');
  vals.push(id);
  
  const stmt = `UPDATE octis_projects SET ${sets.join(', ')} WHERE id=?`;
  db.run(stmt, vals, function(err) {
    if (err) {
      console.error('[server] Updating project error:', err.message);
      return res.status(500).json({ error: 'Database error' });
    }
    
    // Get the updated project record to return
    db.get('SELECT * FROM octis_projects WHERE id = ?', [id], (err, project) => {
      if (err) {
        console.error('[server] Getting updated project error:', err.message);
        return res.status(500).json({ error: 'Database error' });
      }
      res.json({ project });
    });
  });
});

